# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server auth (required for login/register/verify in production)
SUPABASE_SERVICE_ROLE_KEY=
PORTAL_SESSION_SECRET=

# Optional: PostgreSQL direct URL for `npm run db:migrate`
# Supabase > Project Settings > Database > Connection string (URI)
SUPABASE_DB_URL=

# Optional: public app URL for password reset links
NEXT_PUBLIC_APP_URL=https://inkai-jatim.vercel.app
