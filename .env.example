# Supabase — URL project
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy JWT keys (opsional jika pakai publishable/secret baru)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Server secret (wajib untuk login/register/verify)
SUPABASE_SECRET_KEY=

# Portal JWT session cookie (wajib, min 32 karakter random)
PORTAL_SESSION_SECRET=

# Production URL
NEXT_PUBLIC_APP_URL=https://inkai-jatim.vercel.app

# Database — ganti [YOUR-PASSWORD] (Supabase > Database > password)
DIRECT_URL=postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Opsional
SUPABASE_JWKS_URL=
